# Copy this file to .env and fill in your real keys.
# Never commit .env itself — it's in .gitignore.

# === Anthropic (for script rewriting) ===
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000

# === ElevenLabs (for voice cloning TTS) ===
ELEVEN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVEN_VOICE_ID=xxxxxxxxxxxxxxxxxxxx
ELEVEN_MODEL_ID=eleven_v3
ELEVEN_OUTPUT_FORMAT=mp3_44100_128

# === Cloudflare R2 (for hosting audio, future use) ===
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com/<bucket>
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
R2_BUCKET=autopodcast

# === WordPress webhook (future use) ===
WORDPRESS_WEBHOOK_SECRET=
WORDPRESS_BASE_URL=https://blog.shihfenghuang.com

# === Logging (optional) ===
# AUTOPODCAST_LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
