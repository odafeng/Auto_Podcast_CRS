# OpenAI API key – required for script generation and text-to-speech
OPENAI_API_KEY=your_openai_api_key_here

# Model used for script generation (default: gpt-4o)
SCRIPT_MODEL=gpt-4o

# TTS model used for speech synthesis (default: tts-1)
TTS_MODEL=tts-1

# TTS voice: alloy | echo | fable | onyx | nova | shimmer
HOST_VOICE=alloy
GUEST_VOICE=nova

# Directory where generated audio files are saved
OUTPUT_DIR=output
